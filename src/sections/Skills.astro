---
import Terminal from "@components/Terminal.astro";
import ContactMe from "@components/ContactMe.astro";
---

<section id="skills" class="animate-fade-up">
  <div class="w-full flex items-center justify-center gap-4 mb-6">
    <h3 class="text-2xl md:text-3xl font-bold">Skills & Contact me</h3>
    <div class="border-[0.5px] border-solid border-neutral flex-1"></div>
  </div>
  <div class="w-full flex flex-col items-stretch justify-between gap-6">
    <Terminal />
    <ContactMe />
  </div>
</section>


<script>
  import { observeAnimation } from "@utils/observeAnimation";
  observeAnimation("#skills", 100);
</script>