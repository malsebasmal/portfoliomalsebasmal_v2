---
import Verify from "@icons/Verify.astro";
---

<header class="w-full pt-4 pb-4 border-b-2 border-neutral">
  <nav class="w-full h-full flex items-center justify-between">
    <div class="flex items-center justify-center gap-4">
      <h2 class="text-3xl font-bold">Antonio Maldonado E.</h2>
      <Verify />
    </div>
    <ul
      class="flex items-center justify-center gap-8 text-lg [&>li]:cursor-pointer [&>li]:transition-all [&>li:hover]:text-green-secondary [&>li:hover]:font-bold [&>li:hover]:border-b-2"
    >
      <li>About</li>
      <li>Experience</li>
      <li>Stack</li>
      <li>Contact</li>
    </ul>
    <button
      class="px-8 py-4 font-label font-bold rounded-lg bg-rose-primary text-rose-tertiary"
    >
      Download cv
    </button>
  </nav>
</header>
