---
import Verify from "@icons/Verify.astro";
---

<header
  id="header"
  class="animate-fade-up w-full pt-4 pb-4 border-b-2 border-neutral"
>
  <nav class="w-full h-full flex items-center justify-between">
    <div class="flex items-center justify-center gap-4">
      <div class="inline md:hidden">
        <Verify />
      </div>
      <h2 class="hidden sm:inline text-balance text-lg md:text-3xl font-bold">
        Antonio Maldonado E.
      </h2>
      <h2 class="inline sm:hidden text-balance text-lg md:text-3xl font-bold">
        Antonio M. E.
      </h2>
      <div class="hidden md:inline">
        <Verify />
      </div>
    </div>
    <ul
      class="hidden xl:flex items-center justify-center gap-8 text-lg [&>li]:cursor-pointer [&>li]:transition-all [&>li:hover]:text-green-secondary [&>li:hover]:font-bold [&>li:hover]:border-b-2"
    >
      <a href="/#about">About</a>
      <a href="/#experience">Experience</a>
      <a href="/#skills">Skills & Contact me</a>
    </ul>
    <a
      href="/AntonioMaldonado-EN.pdf"
      target="_blank"
      class="cursor-pointer px-4 md:px-8 py-2 md:py-4 font-label font-bold rounded-lg border border-rose-primary bg-rose-primary text-rose-tertiary hover:bg-rose-tertiary hover:text-rose-primary transition-all"
    >
      Download cv
    </a>
  </nav>
</header>

<script>
  import { observeAnimation } from "@utils/observeAnimation";
  observeAnimation("#header", 0);
</script>
