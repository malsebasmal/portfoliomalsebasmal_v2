---
import jobsexperience from "@helpers/jobsexperience";
import CardJobs from "@components/CardJobs.astro";
---

<section class="my-8">
  <div class="w-full flex items-center justify-center gap-4 mb-4">
    <h3 class="text-3xl font-bold">Professional Experience</h3>
    <div class="border-[0.5px] border-solid border-neutral-700 flex-1"></div>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {jobsexperience.map((job) => <CardJobs {...job} />)}
  </div>
</section>
