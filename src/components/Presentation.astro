---
import Languages from "@components/Languages.astro";
---

<div class="flex flex-col xl:flex-row items-stretch justify-between gap-6 mt-6 md:mt-8">
  <div
    id="presentation-card"
    class="animate-fade-up shadow-terminal flex-1 bg-neutral rounded-lg px-6 md:px-8 py-6 md:py-8 flex flex-col items-start justify-center gap-4 md:gap-6 relative overflow-hidden"
  >
    <h3 class="text-pretty text-3xl md:text-4xl font-bold">
      Architecture of Aesthetics
    </h3>
    <p class="text-gray-300 text-balance">
      Frontend Developer specialized in building scalable web interfaces and
      SaaS products. I've worked across real estate platforms, cultural
      organizations, and startups — turning design systems and business
      requirements into clean, performant code. Currently focused on React
      ecosystems, component-driven architecture, and AI-assisted development
      workflows.
    </p>
    <ul class="flex flex-wrap items-center gap-4">
      <li class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4">React Ecosystems</li>
      <li class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4">Component-Driven</li>
      <li class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4">AI Workflows</li>
      <li class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4">Design Systems</li>
    </ul>
  </div>
  <Languages />
</div>

<script>
  import { observeAnimation } from "@utils/observeAnimation";
  observeAnimation("#presentation-card",200);
</script>