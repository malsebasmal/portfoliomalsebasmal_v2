---
import Languages from "@components/Languages.astro";
---

<div
  class="flex flex-col xl:flex-row items-stretch justify-between gap-6 mt-6 md:mt-8"
>
  <div
    id="presentation-card"
    class="animate-fade-up shadow-terminal flex-1 bg-neutral rounded-lg px-6 md:px-8 py-6 md:py-8 flex flex-col items-start justify-center gap-4 md:gap-6 relative overflow-hidden"
  >
    <h3 class="text-pretty text-3xl md:text-4xl font-bold">
      Frontend Developer focused on impact
    </h3>
    <p class="text-gray-300 text-balance">
      Specialized in building scalable web interfaces and SaaS products across
      real estate, fintech, and cultural platforms. I turn design systems and
      business requirements into clean, performant code — working closely with
      teams and clients from first sprint to production.
    </p>
    <ul class="flex flex-wrap items-center gap-4">
      <li
        class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4 transition-all duration-200 hover:shadow-[0_0_10px_var(--color-green-secondary)] hover:border-green-secondary/80 hover:bg-green-secondary/10 cursor-default"
      >
        React · Next.js · TypeScript
      </li>
      <li
        class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4 transition-all duration-200 hover:shadow-[0_0_10px_var(--color-green-secondary)] hover:border-green-secondary/80 hover:bg-green-secondary/10 cursor-default"
      >
        Tailwind
      </li>
      <li
        class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4 transition-all duration-200 hover:shadow-[0_0_10px_var(--color-green-secondary)] hover:border-green-secondary/80 hover:bg-green-secondary/10 cursor-default"
      >
        SaaS Products
      </li>
      <li
        class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4 transition-all duration-200 hover:shadow-[0_0_10px_var(--color-green-secondary)] hover:border-green-secondary/80 hover:bg-green-secondary/10 cursor-default"
      >
        Component-Driven
      </li>
      <li
        class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4 transition-all duration-200 hover:shadow-[0_0_10px_var(--color-green-secondary)] hover:border-green-secondary/80 hover:bg-green-secondary/10 cursor-default"
      >
        AI assisted-workflow
      </li>
      <li
        class="bg-green-text-background text-green-secondary border-green-secondary border rounded-full text-sm tracking-wide px-4 transition-all duration-200 hover:shadow-[0_0_10px_var(--color-green-secondary)] hover:border-green-secondary/80 hover:bg-green-secondary/10 cursor-default"
      >
        Design Systems
      </li>
    </ul>
  </div>
  <Languages />
</div>

<script>
  import { observeAnimation } from "@utils/observeAnimation";
  observeAnimation("#presentation-card", 200);
</script>
