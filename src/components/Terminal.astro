---
// TerminalSkills.astro
// Terminal-style skills component with animated typewriter effect
---

<div class="flex-1 terminal-wrapper">
  <div class="terminal-window">
    <!-- Window chrome -->
    <div class="terminal-header">
      <div class="traffic-lights">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
      </div>
      <span class="terminal-title text-base md:text-lg"
        >antonio@portfolio: ~</span
      >
    </div>

    <!-- Terminal body -->
    <div class="terminal-body">
      <div class="terminal-grid">
        <!-- Left panel: ls stack/ -->
        <div class="terminal-panel" id="panel-left">
          <div class="terminal-line prompt-line">
            <span class="prompt-user">antonio@portfolio</span><span
              class="prompt-separator">:</span
            ><span class="prompt-path">~</span><span class="prompt-dollar"
              >$</span
            >
            <span class="cmd cmd-left"></span>
          </div>

          <ul class="stack-list">
            <li class="stack-item" style="--delay: 0.9s">
              <span class="stack-arrow">›</span>
              <span class="stack-text">TypeScript / React / Next.js</span>
            </li>
            <li class="stack-item" style="--delay: 1.1s">
              <span class="stack-arrow">›</span>
              <span class="stack-text">Astro / Tailwind CSS</span>
            </li>
            <li class="stack-item" style="--delay: 1.3s">
              <span class="stack-arrow">›</span>
              <span class="stack-text">TanStack Query / REST APIs</span>
            </li>
            <li class="stack-item" style="--delay: 1.5s">
              <span class="stack-arrow">›</span>
              <span class="stack-text">Figma / GitLab</span>
            </li>
          </ul>
        </div>

        <!-- Vertical divider -->
        <div class="terminal-divider"></div>

        <!-- Right panel: cat focus.txt -->
        <div class="mt-4 lg:mt-0 terminal-panel" id="panel-right">
          <div class="terminal-line prompt-line">
            <span class="prompt-user">antonio@portfolio</span><span
              class="prompt-separator">:</span
            ><span class="prompt-path">~</span><span class="prompt-dollar"
              >$</span
            >
            <span class="cmd cmd-right"></span>
          </div>

          <p class="focus-text text-balance md:text-pretty">
            "Building performant, accessible, and scalable frontend
            architectures with a component-first mindset."
          </p>

          <div class="terminal-line prompt-line second-prompt">
            <span class="prompt-user">antonio@portfolio</span><span
              class="prompt-separator">:</span
            ><span class="prompt-path">~</span><span class="prompt-dollar"
              >$</span
            >
            <span class="cursor-blink">_</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .terminal-wrapper {
    display: block;
    width: 100%;
    font-family: "JetBrains Mono Variable", monospace;
  }

  .terminal-window {
    background-color: var(--color-neutral);
    border-radius: 0.75rem;
    overflow: hidden;
    width: 100%;
    box-shadow:
      0 0 0 1px
        color-mix(in srgb, var(--color-green-secondary) 15%, transparent),
      0 25px 60px color-mix(in srgb, black 60%, transparent),
      0 0 80px color-mix(in srgb, var(--color-green-primary) 10%, transparent);
  }

  /* ── Header ─────────────────────────────────── */
  .terminal-header {
    background-color: color-mix(in srgb, var(--color-neutral) 80%, black);
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    border-bottom: 1px solid
      color-mix(in srgb, var(--color-green-primary) 30%, transparent);
  }

  .traffic-lights {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: block;
  }

  .dot-red {
    background-color: #ff5f56;
  }
  .dot-yellow {
    background-color: #ffbd2e;
  }
  .dot-green {
    background-color: #27c93f;
  }

  .terminal-title {
    color: color-mix(in srgb, var(--color-green-secondary) 50%, transparent);
    letter-spacing: 0.04em;
  }

  /* ── Body ───────────────────────────────────── */
  .terminal-body {
    padding: 1.5rem 1.75rem 1.75rem;
    background-color: var(--color-neutral);
  }

  .terminal-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 0 1.5rem;
  }

  .terminal-divider {
    background: color-mix(in srgb, var(--color-green-primary) 40%, transparent);
    align-self: stretch;
  }

  .terminal-panel {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Prompt ─────────────────────────────────── */
  .terminal-line {
    display: flex;
    align-items: baseline;
    line-height: 1.5;
  }

  .prompt-user {
    color: var(--color-green-secondary);
    font-weight: 600;
  }

  .prompt-separator,
  .prompt-path {
    color: color-mix(in srgb, var(--color-green-secondary) 60%, transparent);
  }

  .prompt-dollar {
    color: color-mix(in srgb, var(--color-green-secondary) 70%, transparent);
    margin-left: 0.25rem;
    margin-right: 0.5rem;
  }

  /* ── Typewriter commands ────────────────────── */
  .cmd {
    color: #e8e8e8;
    overflow: hidden;
    white-space: nowrap;
    display: inline-block;
    width: 0;
  }

  .cmd-left::after {
    content: "ls stack/";
  }
  .cmd-right::after {
    content: "cat focus.txt";
  }

  .cmd-left {
    animation: type-left 0.5s steps(10, end) 0.2s forwards;
  }

  .cmd-right {
    animation: type-right 0.5s steps(13, end) 1.6s forwards;
  }

  /* ── Stack list ─────────────────────────────── */
  .stack-list {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .stack-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    transform: translateX(-6px);
    animation: fade-slide-in 0.3s ease forwards;
    animation-delay: var(--delay, 1s);
  }

  .stack-arrow {
    color: var(--color-green-secondary);
    flex-shrink: 0;
  }

  .stack-text {
    color: #d4d4d4;
    line-height: 1.5;
  }

  /* ── Focus text ─────────────────────────────── */
  .focus-text {
    color: color-mix(in srgb, #e8e8e8 85%, transparent);
    line-height: 1.75;
    font-style: italic;
    margin: 0.25rem 0 0;
    opacity: 0;
    animation: fade-in 0.5s ease forwards;
    animation-delay: 2.3s;
  }

  /* ── Second prompt ──────────────────────────── */
  .second-prompt {
    opacity: 0;
    animation: fade-in 0.3s ease forwards;
    animation-delay: 2.9s;
    margin-top: 0.25rem;
  }

  /* ── Blinking cursor ────────────────────────── */
  .cursor-blink {
    color: var(--color-green-secondary);
    animation: blink 1.1s step-end infinite;
    margin-left: 0.1rem;
  }

  /* ── Keyframes ──────────────────────────────── */
  @keyframes type-left {
    from {
      width: 0;
    }
    to {
      width: 10ch;
    }
  }

  @keyframes type-right {
    from {
      width: 0;
    }
    to {
      width: 13ch;
    }
  }

  @keyframes fade-slide-in {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes fade-in {
    to {
      opacity: 1;
    }
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 900px) {
    .terminal-grid {
      grid-template-columns: 1fr;
    }

    .terminal-divider {
      display: none;
    }

    .terminal-body {
      padding: 1.25rem;
    }
  }
</style>
