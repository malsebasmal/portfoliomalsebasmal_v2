---
import Leaf from "@icons/Leaf.astro";
import Send from "@icons/Send.astro";
import Linkedin from "@icons/LinkedIn.astro";
import GitHub from "@icons/Github.astro";
---

<div
  class="shadow-terminal flex-1 w-full rounded-lg bg-neutral px-6 md:px-8 py-6 md:py-8 flex flex-col xl:flex-row items-stretch justify-between gap-4"
>
  <div class="flex items-center justify-center gap-8">
    <div
      class="hidden md:inline w-fit px-4 py-4 bg-green-text-background border-green-secondary border rounded-md"
    >
      <Leaf />
    </div>
    <div class="flex flex-col items-start gap-2">
      <p class="text-3xl md:text-4xl font-bold">Let's build something great.</p>
      <p class="text-xl md:text-2xl text-gray-300">
        Open to new roles, freelance projects, and interesting collaborations.
      </p>
    </div>
  </div>
  <div class="w-full md:w-md flex flex-col items-center justify-center gap-4">
    <button
      class="w-full flex items-center justify-center gap-2 px-4 md:px-8 py-2 md:py-4 font-label font-bold rounded-md border border-rose-primary bg-rose-primary text-rose-tertiary hover:bg-rose-tertiary hover:text-rose-primary transition-all"
    >
      <Send />
      Send Message
    </button>
    <div class="w-full flex items-center justify-center gap-4">
      <a
        class="w-full flex items-center justify-center gap-2 px-4 md:px-8 py-2 md:py-4 font-label font-bold rounded-md border border-green-secondary bg-green-secondary text-green-text-background hover:bg-green-text-background hover:text-green-secondary transition-all"
        href="https://www.linkedin.com/in/antoniomaldonadotech/"
        target="_blank"
      >
        <Linkedin />
        LinkedIn
      </a>
      <a
        class="w-full flex items-center justify-center gap-2 px-4 md:px-8 py-2 md:py-4 font-label font-bold rounded-md border border-green-secondary bg-green-secondary text-green-text-background hover:bg-green-text-background hover:text-green-secondary transition-all"
        href="https://github.com/malsebasmal"
        target="_blank"
      >
        <GitHub />
        GitHub
      </a>
    </div>
  </div>
</div>
